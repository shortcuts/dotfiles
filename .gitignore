# ignore everything but the lines below
# NOTE: for whitelisted directories we need both `!dir/` (un-ignore the dir
# so git descends into it) AND `!dir/**` (un-ignore its contents). Without
# the `**` rule, new files inside the dir get re-ignored by `*`.
*

# rpi
!rpi/
!rpi/**
!dnsmasq.conf

# docs
!*.md

# window manager config
!aerospace/
!aerospace/**
!borders/
!borders/**

# term
!ghostty/
!ghostty/**
!btop/
!btop/**

# nvim config
!nvim/
!nvim/**
!stylua.toml

# fish config
!fish/
fish/*
!fish/config.fish
!fish/alias.fish
!fish/themes/
!fish/themes/**
!fish/conf.d/
fish/conf.d/*
!fish/conf.d/tmux_autorename.fish
!fish/functions/
fish/functions/*
!fish/functions/g*
!fish/functions/rmdocker*
fish/fish_variables*
!fisher/
!fisher/**

# pkg manager
!mise/
!mise/**

# starship config
!starship.toml

# github workflows
!.git*
!.github/
!.github/**

# tmux
!tmux/
!tmux/**
!scripts/
!scripts/**

# keyboard
!keyboard/
!keyboard/**

# 3D printing / STL
!STL/
!STL/**

# ai takeover
!opencode/
opencode/*
!opencode/oh-my-openagent.json
!opencode/.gitignore
!.claude/
!.claude/settings.json
!.claude/CLAUDE.md
!.claude/skills/
!.claude/skills/**
