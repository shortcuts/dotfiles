{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__code-review-graph__*",
      "Bash(./gradlew *)"
    ],
    "deny": [
      "Bash(make deploy)",
      "Bash(terraform apply)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy)",
      "Bash(terraform destroy *)"
    ],
    "ask": [
      "Bash(go build)",
      "Bash(go build *)",
      "Bash(chmod *)",
      "Bash(chmod 777:*)",
      "Bash(chown *)",
      "Bash(docker *)",
      "Bash(eval:*)",
      "Bash(curl *)",
      "Bash(fdisk *)",
      "Bash(gcloud *)",
      "Bash(git clean -fd:*)",
      "Bash(git reset *)",
      "Bash(git rebase *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(kubectl *)",
      "Bash(mkfs *)",
      "Bash(npm publish*)",
      "Bash(pkill *)",
      "Bash(pnpm publish*)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(shred *)",
      "Bash(sudo:*)",
      "Bash(unlink *)",
      "Bash(wget *)",
      "Bash(yarn publish*)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(**/*credential*)",
      "Read(**/*secret*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.aws/**)",
      "Read(~/.azure/**)",
      "Read(~/.ssh/**)",
      "Bash(cat *.key)",
      "Bash(cat *.pem)",
      "Bash(cat *credential*)",
      "Bash(cat *secret*)",
      "Bash(cat .env)",
      "Bash(cat .env.*)",
      "Bash(cat ~/.aws/*)",
      "Bash(cat ~/.azure/*)",
      "Bash(cat ~/.ssh/*)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/local/Cellar/node/26.5.0/bin/node\" \"/Users/k/.claude/hooks/caveman-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading caveman mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/usr/local/Cellar/node/26.5.0/bin/node\" \"/Users/k/.claude/hooks/caveman-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking caveman mode..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.local/share/mise/installs/node/latest/bin/ccstatusline",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "caveman@caveman": true,
    "lua-lsp@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "clangd-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "i-have-adhd@i-have-adhd": true,
    "humanizer@humanizer": true,
    "ponytail@ponytail": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "i-have-adhd": {
      "source": {
        "source": "github",
        "repo": "ayghri/i-have-adhd"
      }
    },
    "humanizer": {
      "source": {
        "source": "github",
        "repo": "blader/humanizer"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "medium",
  "theme": "auto",
  "remoteControlAtStartup": false,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
